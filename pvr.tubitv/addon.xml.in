<?xml version="1.0" encoding="UTF-8"?>
<addon id="pvr.tubitv"
       version="1.0.0"
       name="Tubi TV PVR Client"
       provider-name="Team Kodi, Asmodasis">
  <requires>@ADDON_DEPENDS@
    <import addon="inputstream.adaptive" minversion="22.0.0"/>
  </requires>
  <extension
    point="kodi.pvrclient"
    library_@PLATFORM@="@LIBRARY_FILENAME@"/>
  <extension point="xbmc.addon.metadata">
    <platform>@PLATFORM@</platform>
    <license>GPL-2.0-or-later</license>
    <source>https://github.com/kodi-pvr/pvr.tubitv</source>
    <forum>https://forum.kodi.tv/forumdisplay.php?fid=167</forum>
    <assets>
      <icon>icon.PNG</icon>
      <screenshot>resources/screenshots/screenshot-01.png</screenshot>
      <screenshot>resources/screenshots/screenshot-02.png</screenshot>
      <screenshot>resources/screenshots/screenshot-03.png</screenshot>
    </assets>
    <summary lang="en_us">Tubi TV Live channels in Kodi</summary>
    <description lang="en_us">Provides live TV channels and EPG data from Tubi TV. This addon is unofficial and not affiliated with or endorsed by Tubi.</description>
  </extension>
</addon>
